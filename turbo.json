{
    "tasks": {
        "dev": {
            "cache": false,
            "persistent": true
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "build/**",
                ".react-router/**"
            ]
        },
        "@huposit/api#build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "@huposit/worker#build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": []
        },
        "test": {},
        "lint": {},
        "typecheck": {},
        "sync": {
            "cache": false
        }
    }
}
